# ──────────────────────────────────────────────────
# VinFast AI Chatbot — Environment Variables
# Sao chép file này thành .env và điền API keys thực
# ──────────────────────────────────────────────────

# ── LLM API Keys (ưu tiên: Claude → GitHub Models → Gemini) ──
# Điền ít nhất một key để backend hoạt động với LLM thực.
# Nếu không điền, server sẽ chạy ở chế độ Mock Fallback.

OPENROUTER_API_KEY=sk-proj-placeholder-...
ANTHROPIC_API_KEY=sk-placeholder-your-claude-key-here
OPENAI_API_KEY=sk-proj-placeholder-...
GITHUB_PAT=ghp_placeholder-your-github-pat-here
GOOGLE_API_KEY=AIza_placeholder-your-gemini-key-here
VOYAGE_API_KEY=pa-placeholder-your-voyage-key-here

# ── LangSmith Tracking (tuỳ chọn) ──
# Dùng để theo dõi và debug LangGraph traces trên langsmith.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=lsv2_placeholder-your-langsmith-key
LANGCHAIN_PROJECT=vinfast-ai-chatbot

# ── Response Cache (MVP) ──
ENABLE_RESPONSE_CACHE=true
CACHE_TTL_POLICY_SECONDS=600
CACHE_TTL_REVIEW_SECONDS=300
CACHE_TTL_MAINTENANCE_SECONDS=300
CACHE_TTL_SPEC_SECONDS=600
CACHE_TTL_CHARGING_SECONDS=600
CACHE_TTL_GENERIC_SECONDS=300

# ── Server Config ──
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
